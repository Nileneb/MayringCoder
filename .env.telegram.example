# Telegram Bot Configuration
# Copy to .env.telegram and fill in your values

# 1. Get from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 2. Get from @userinfobot on Telegram
TELEGRAM_ALLOWED_IDS=123456789

# 3. Workspaces — add as many WORKSPACE_<NAME>=<path> as you want
WORKSPACE_MAYRNG=/home/nileneb/Desktop/MayringCoder
WORKSPACE_NEW=/home/nileneb/Desktop/NewProject

# 4. Path to claude binary (default: claude, assumes it's on PATH)
CLAUDE_BIN=claude
