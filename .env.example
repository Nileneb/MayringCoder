GITHUB_REPO=https://github.com/Nileneb/app.linn.games
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
GITHUB_TOKEN=

# Multi-Tenancy API Server (src/api_server.py)
# Start: .venv/bin/python -m uvicorn src.api_server:app --port 8080
APP_BASE_URL=https://your-server.example.com

# Sanctum Auth (app.linn.games MySQL — same Docker stack)
# Tokens are generated in app.linn.games and used as Bearer tokens here
LARAVEL_DB_HOST=mysql
LARAVEL_DB_PORT=3306
LARAVEL_DB_USER=laravel
LARAVEL_DB_PASSWORD=
LARAVEL_DB_NAME=laravel

# MCP Server Transport
# stdio: für Claude Code (lokal, kein Port)
# http:  für app.linn.games / Remote-Zugriff (Port 8000)
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8000
MCP_HTTP_HOST=0.0.0.0
# Shared Secret für HTTP-Modus (leer = kein Auth, nur lokal)
MCP_AUTH_TOKEN=

# JWT Auth (optional, für Workspace-Isolation)
# MCP_AUTH_ENABLED=false
# MCP_AUTH_SECRET=your-hmac-secret-here
# Token generieren: python tools/generate_mcp_token.py --workspace X --secret $MCP_AUTH_SECRET

# Docker Full Pipeline (docker-compose.full.yml)
# GRADIO_PORT=7860

# GPU-Monitoring (optional, benötigt nvidia-smi)
# Aktiviert mit: checker.py --gpu-metrics
# Ausgabe: cache/gpu_metrics_<timestamp>.csv

# Training Pipeline + Langdock Annotation Webhook
# Zufälliger Secret-String für eingehende Langdock-Webhooks
LANGDOCK_WEBHOOK_SECRET=

# Langdock API Key (optional, für programmatischen Push zu Langdock)
LANGDOCK_API_KEY=

# Output-Verzeichnis für Fine-tuned Models
FINETUNE_OUTPUT_DIR=./models/finetuned
