# MayringCoder — Konfigurationsvorlage
# cp .env.example .env  →  Werte eintragen  →  nie committen!
# Produktion: GitHub Actions schreibt diese Variablen via Secrets in ~/app.linn.games/.env.mayring

# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_SSL_VERIFY=true
# Modelle werden NICHT per ENV konfiguriert → config/model_routes.yaml / Web-UI Einstellungen

# ── MCP / FastAPI ──────────────────────────────────────────────────────────
APP_BASE_URL=https://mcp.linn.games
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8092
MCP_HTTP_HOST=0.0.0.0

# ── Auth: RS256 JWT ─────────────────────────────────────────────────────────
MCP_AUTH_ENABLED=false
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ISSUER=https://app.linn.games
JWT_AUDIENCE=mayringcoder
MCP_SERVICE_TOKEN=

# ── Pi Agent ───────────────────────────────────────────────────────────────
PI_REPO_SLUG=Nileneb/app.linn.games

# ── Docker (Production) ────────────────────────────────────────────────────
MAYRING_API_URL=http://mayring-api:8090
LARAVEL_NETWORK=linn-shared
MAYRING_PORT=6480
CLAUDE_PROJECTS_DIR=
