# MayringCoder Production — Server app.linn.games
# cp .env.production.example .env.production  →  Secrets eintragen  →  nie committen!

# ── Ollama (läuft auf lokalem PC, erreichbar über IP-Allowlist im Proxy) ──
OLLAMA_URL=http://192.168.178.11:11434
OLLAMA_MODEL=qwen3.5:2b

# ── Pi Agent ───────────────────────────────────────────────────────────────
PI_REPO_SLUG=Nileneb/app.linn.games

# ── Sanctum Auth (app.linn.games MySQL — selber Docker-Stack) ─────────────
LARAVEL_DB_HOST=mysql
LARAVEL_DB_PORT=3306
LARAVEL_DB_USER=laravel
LARAVEL_DB_PASSWORD=
LARAVEL_DB_NAME=laravel

# ── MCP HTTP Auth (gleicher Wert wie MAYRING_MCP_AUTH_TOKEN in Laravel .env)
MCP_AUTH_TOKEN=

# ── FastAPI ────────────────────────────────────────────────────────────────
APP_BASE_URL=https://app.linn.games

# ── Gradio Web-UI (Basic Auth für kommerzielle Nutzung) ───────────────────
UI_AUTH_USER=admin
UI_AUTH_PASS=

# ── Docker-Netzwerk von app.linn.games ─────────────────────────────────────
# Namen herausfinden: docker network ls | grep linn
LARAVEL_NETWORK=app_linn_games_default
