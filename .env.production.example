# MayringCoder Production — Server app.linn.games
# Dateiname auf Server: .env.mayring  (NICHT .env.production — kein shared env mit Laravel!)
# cp .env.production.example .env.mayring  →  Secrets eintragen  →  nie committen!

# ── Ollama (läuft auf three.linn.games — NICHT auf Production-Server deployen!) ──
# SSL-Cert auf three.linn.games gilt für www.linn.games, nicht three.linn.games
# → OLLAMA_SSL_VERIFY=false ist erforderlich bis das Cert erneuert wird
OLLAMA_URL=https://three.linn.games
OLLAMA_SSL_VERIFY=false
# OLLAMA_MODEL ist NICHT mehr konfiguriert — Modelle werden über config/model_routes.yaml gesteuert.
# Änderungen zur Laufzeit: Web-UI Einstellungen-Tab oder config/model_routes.yaml editieren.

# ── Pi Agent ───────────────────────────────────────────────────────────────
PI_REPO_SLUG=Nileneb/app.linn.games

# ── Auth: RS256 JWT ─────────────────────────────────────────────────────────
# app.linn.games holds the RSA private key and signs JWTs. MayringCoder only
# verifies with the matching public key. Required claims: exp, iss, aud,
# workspace_id. Admin access via scope: ["admin"].
MCP_AUTH_ENABLED=true
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem
JWT_ISSUER=https://app.linn.games
JWT_AUDIENCE=mayringcoder

# Service-to-service token for POST /authorize/register-code
# (app.linn.games → MayringCoder OAuth code registration). Rotate periodically.
MCP_SERVICE_TOKEN=

# ── FastAPI ────────────────────────────────────────────────────────────────
APP_BASE_URL=https://mcp.linn.games

# ── Web-UI: API-Server URL (intern im Docker-Netzwerk) ────────────────────
# Für Production: http://api-server:8080 (Docker-DNS)
# Für lokale Entwicklung: http://localhost:8080
MAYRING_API_URL=http://api-server:8080

# ── Docker-Netzwerk von app.linn.games ─────────────────────────────────────
# Namen herausfinden: docker network ls | grep linn
LARAVEL_NETWORK=linn-shared
